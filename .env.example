    # ==========================================
    # FairShare Environment Variables Template
    # ==========================================
    # INSTRUCTIONS: Copy this file, rename it to '.env', and fill in your actual secure values.
    # DO NOT push your actual '.env' file to GitHub!

    # Database Configuration
    DB_NAME=fairsharedb
    DB_USER=postgres
    DB_PASSWORD=your_super_secure_database_password_here

    # Security
    # Generate a secure 256-bit key for your JWTs
    JWT_SECRET=your_super_secure_jwt_secret_key_that_is_very_long_and_random

    # Spring Boot Configuration
    SPRING_PROFILE=prod